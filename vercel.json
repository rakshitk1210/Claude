{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install && cd iterations/v12 && npm install",
  "buildCommand": "cd iterations/v12 && npm run build",
  "outputDirectory": ".",
  "functions": {
    "api/chat.ts": {
      "maxDuration": 60
    },
    "api/document.ts": {
      "maxDuration": 120
    },
    "api/inline-edit.ts": {
      "maxDuration": 120
    },
    "api/document-revise.ts": {
      "maxDuration": 120
    }
  }
}
